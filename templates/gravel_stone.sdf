  <link name="stone_{idx}">
    <pose>{x} {y} {z} 0 0 0</pose>
    <collision name="c">
      <geometry>
        <sphere><radius>{r}</radius></sphere>
      </geometry>
    </collision>
    <visual name="v">
      <geometry>
        <sphere><radius>{r}</radius></sphere>
      </geometry>
      <material>
        <ambient>{cr} {cg} {cb} 1</ambient>
        <diffuse>{cr} {cg} {cb} 1</diffuse>
      </material>
    </visual>
  </link>
